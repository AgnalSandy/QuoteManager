{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=aspnet-QuoteManager;MultipleActiveResultSets=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 60,
    "MasterDataExpirationMinutes": 120
  },
  "PerformanceSettings": {
    "DefaultPageSize": 20,
    "MaxPageSize": 100,
    "SlowRequestThresholdMs": 1000
  },
  "SecuritySettings": {
    "RequireHttps": true,
    "EnableSecurityHeaders": true,
    "SessionTimeoutMinutes": 30
  },
  "AllowedHosts": "*"
}
