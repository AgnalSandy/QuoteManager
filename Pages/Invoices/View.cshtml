@page
@model QuoteManager.Pages.Invoices.ViewModel
@{
    ViewData["Title"] = $"Invoice {Model.Invoice.InvoiceNumber}";
    Layout = null; // No layout for printing
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        @@media print {
            .no-print { display: none !important; }
            body { margin: 0; }
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
    </style>
</head>
<body>
    <!-- Print Button -->
    <div class="no-print text-center py-3 bg-light">
        <button onclick="window.print()" class="btn btn-primary">
            <i class="bi bi-printer"></i> Print Invoice
        </button>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a href="/Invoices/Edit?id=@Model.Invoice.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit Invoice
            </a>
        }
        <a href="/Invoices/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <!-- Template Dispatcher -->
    @if (Model.Invoice.TemplateType == "Professional")
    {
        <partial name="_TemplateProfessional" model="Model" />
    }
    else if (Model.Invoice.TemplateType == "Minimal")
    {
        <partial name="_TemplateMinimal" model="Model" />
    }
    else if (Model.Invoice.TemplateType == "Modern")
    {
        <partial name="_TemplateModern" model="Model" />
    }
    else
    {
        <!-- Default to Professional -->
        <partial name="_TemplateProfessional" model="Model" />
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
