@page
@model QuoteManager.Pages.Invoices.IndexModel
@{
    ViewData["Title"] = "Invoices";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-file-invoice-dollar"></i> Invoices</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <a asp-page="/Invoices/Create" class="btn btn-primary">
                            <i class="fas fa-plus"></i> New Invoice
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (Model.Invoices.Count == 0)
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> No invoices found. Generate an invoice from an accepted quote.
            </div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-header bg-primary">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-list"></i> All Invoices (@Model.Invoices.Count)
                    </h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th>Invoice #</th>
                                <th>Client</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Template</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invoice in Model.Invoices)
                            {
                                <tr>
                                    <td><strong>@invoice.InvoiceNumber</strong></td>
                                    <td>@invoice.ClientName</td>
                                    <td>@invoice.InvoiceDate.ToString("dd MMM yyyy")</td>
                                    <td><strong>₹@invoice.GrandTotal.ToString("N2")</strong></td>
                                    <td>
                                        <span class="badge badge-info">@invoice.TemplateType</span>
                                    </td>
                                    <td>
                                        @if (invoice.Status == "Paid")
                                        {
                                            <span class="badge badge-success">Paid</span>
                                        }
                                        else if (invoice.Status == "Unpaid")
                                        {
                                            <span class="badge badge-warning">Unpaid</span>
                                        }
                                        else if (invoice.Status == "Overdue")
                                        {
                                            <span class="badge badge-danger">Overdue</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">@invoice.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-page="View" asp-route-id="@invoice.Id" class="btn btn-sm btn-primary" target="_blank" title="View Invoice">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Staff"))
                                        {
                                            <a asp-page="Edit" asp-route-id="@invoice.Id" class="btn btn-sm btn-warning" title="Edit Invoice">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            @if (invoice.Status == "Unpaid")
                                            {
                                                <a asp-page="Delete" asp-route-id="@invoice.Id" class="btn btn-sm btn-danger" title="Delete Invoice">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-secondary" disabled title="Only unpaid invoices can be deleted">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>
