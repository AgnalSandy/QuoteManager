@page
@model QuoteManager.Pages.Invoices.CreateModel
@{
    ViewData["Title"] = "Generate Invoice";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-file-invoice-dollar"></i> Generate Invoice</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="./Index">Invoices</a></li>
                    <li class="breadcrumb-item active">Generate</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <!-- Preview Info Alert -->
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <h5><i class="fas fa-eye"></i> Preview Templates First!</h5>
                    <p class="mb-2">Not sure which template to use? <a href="/Invoices/Preview" target="_blank" class="alert-link font-weight-bold">Click here to preview all templates</a> with sample data before creating your invoice.</p>
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header bg-primary">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-info-circle"></i> Invoice Details
                        </h3>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <div class="form-group">
                                <label asp-for="Input.QuoteId">Quote <span class="text-danger">*</span></label>
                                <select asp-for="Input.QuoteId" asp-items="Model.Input.AvailableQuotes" class="form-control">
                                    <option value="">-- Select Quote --</option>
                                </select>
                                <span asp-validation-for="Input.QuoteId" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    <i class="fas fa-info-circle"></i> Only accepted quotes are shown
                                </small>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Input.DueDate">Due Date</label>
                                        <input asp-for="Input.DueDate" class="form-control" type="date" />
                                        <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Input.Discount">Discount <small class="text-muted">(Optional)</small></label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">₹</span>
                                            </div>
                                            <input asp-for="Input.Discount" class="form-control" placeholder="0.00" />
                                        </div>
                                        <span asp-validation-for="Input.Discount" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.TemplateType">Template Style</label>
                                <div class="input-group">
                                    <select asp-for="Input.TemplateType" asp-items="Model.Input.AvailableTemplates" class="form-control">
                                    </select>
                                    <div class="input-group-append">
                                        <a href="/Invoices/Preview" target="_blank" class="btn btn-outline-info" title="Preview templates">
                                            <i class="fas fa-eye"></i> Preview Templates
                                        </a>
                                    </div>
                                </div>
                                <span asp-validation-for="Input.TemplateType" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    <i class="fas fa-palette"></i> Choose invoice design style | <a href="/Invoices/Preview" target="_blank"><i class="fas fa-external-link-alt"></i> Preview all templates with sample data</a>
                                </small>
                            </div>

                            <hr class="my-4" />

                            <h5 class="mb-3"><i class="fas fa-university"></i> Bank Details <small class="text-muted">(Optional)</small></h5>

                            <div class="form-group">
                                <label asp-for="Input.BankName">Bank Name</label>
                                <input asp-for="Input.BankName" class="form-control" placeholder="e.g., HDFC Bank" />
                                <span asp-validation-for="Input.BankName" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Input.AccountName">Account Name</label>
                                        <input asp-for="Input.AccountName" class="form-control" />
                                        <span asp-validation-for="Input.AccountName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Input.AccountNumber">Account Number</label>
                                        <input asp-for="Input.AccountNumber" class="form-control" />
                                        <span asp-validation-for="Input.AccountNumber" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mb-0">
                                <label asp-for="Input.Notes">Notes <small class="text-muted">(Optional)</small></label>
                                <textarea asp-for="Input.Notes" class="form-control" rows="3"
                                          placeholder="Additional notes for the invoice"></textarea>
                                <span asp-validation-for="Input.Notes" class="text-danger"></span>
                            </div>

                            <hr class="my-4" />

                            <div class="text-center">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-file-invoice"></i> Generate Invoice
                                </button>
                                <a asp-page="./Index" class="btn btn-secondary btn-lg">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
