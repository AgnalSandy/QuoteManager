@page
@model QuoteManager.Pages.CompanySettings.EditModel
@{
    ViewData["Title"] = "Company Settings";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="mb-4">
        <h1 class="h3 mb-2">Company Settings</h1>
        <p class="text-muted">Configure your company information for invoices and quotes</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Input.Id" />
        <input type="hidden" asp-for="Input.LogoPath" />

        <div class="row">
            <div class="col-lg-8">
                <!-- Company Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-building"></i> Company Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Input.CompanyName" class="form-label"></label>
                            <input asp-for="Input.CompanyName" class="form-control" />
                            <span asp-validation-for="Input.CompanyName" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Email" class="form-label"></label>
                                <input asp-for="Input.Email" class="form-control" type="email" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Website" class="form-label"></label>
                                <input asp-for="Input.Website" class="form-control" />
                                <span asp-validation-for="Input.Website" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Address -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Address</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Input.AddressLine1" class="form-label"></label>
                            <input asp-for="Input.AddressLine1" class="form-control" />
                            <span asp-validation-for="Input.AddressLine1" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.AddressLine2" class="form-label"></label>
                            <input asp-for="Input.AddressLine2" class="form-control" />
                            <span asp-validation-for="Input.AddressLine2" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.City" class="form-label"></label>
                                <input asp-for="Input.City" class="form-control" />
                                <span asp-validation-for="Input.City" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.State" class="form-label"></label>
                                <input asp-for="Input.State" class="form-control" />
                                <span asp-validation-for="Input.State" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.PinCode" class="form-label"></label>
                                <input asp-for="Input.PinCode" class="form-control" />
                                <span asp-validation-for="Input.PinCode" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Country" class="form-label"></label>
                                <input asp-for="Input.Country" class="form-control" />
                                <span asp-validation-for="Input.Country" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-telephone"></i> Contact Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                                <input asp-for="Input.PhoneNumber" class="form-control" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.SecondaryPhone" class="form-label"></label>
                                <input asp-for="Input.SecondaryPhone" class="form-control" />
                                <span asp-validation-for="Input.SecondaryPhone" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Input.WhatsAppNumber" class="form-label"></label>
                                <input asp-for="Input.WhatsAppNumber" class="form-control" />
                                <span asp-validation-for="Input.WhatsAppNumber" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tax Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-receipt"></i> Tax Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.GSTNumber" class="form-label"></label>
                                <input asp-for="Input.GSTNumber" class="form-control" placeholder="22AAAAA0000A1Z5" />
                                <span asp-validation-for="Input.GSTNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.PANNumber" class="form-label"></label>
                                <input asp-for="Input.PANNumber" class="form-control" placeholder="AAAAA0000A" />
                                <span asp-validation-for="Input.PANNumber" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Message -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-chat-quote"></i> Invoice Footer</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-0">
                            <label asp-for="Input.FooterMessage" class="form-label"></label>
                            <textarea asp-for="Input.FooterMessage" class="form-control" rows="3" 
                                      placeholder="Thank you for your business!"></textarea>
                            <span asp-validation-for="Input.FooterMessage" class="text-danger"></span>
                            <div class="form-text">This message will appear at the bottom of invoices</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Company Logo -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-image"></i> Company Logo</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Input.LogoPath))
                        {
                            <div class="text-center mb-3">
                                <img src="@Model.Input.LogoPath" alt="Company Logo" class="img-fluid rounded" style="max-height: 200px;" />
                            </div>
                        }
                        else
                        {
                            <div class="text-center mb-3 p-4 bg-light rounded">
                                <i class="bi bi-image" style="font-size: 4rem; color: #ccc;"></i>
                                <p class="text-muted mt-2 mb-0">No logo uploaded</p>
                            </div>
                        }

                        <div class="mb-0">
                            <label asp-for="Input.LogoFile" class="form-label"></label>
                            <input asp-for="Input.LogoFile" class="form-control" type="file" accept="image/*" />
                            <span asp-validation-for="Input.LogoFile" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-info-circle"></i> Recommended: PNG or JPG, max 2MB, square ratio (200x200px)
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Save Button -->
                <div class="card shadow-sm">
                    <div class="card-body">
                        <button type="submit" class="btn btn-primary w-100 mb-2">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                        <a asp-page="/Dashboard/Index" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-arrow-left"></i> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
