@page
@model QuoteManager.Pages.ServiceMasters.EditModel
@{
    ViewData["Title"] = "Edit Service";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="mb-4">
        <h1 class="h3 mb-2">Edit Service</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-page="./Index">Service Master</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Input.Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.ServiceName" class="form-label"></label>
                            <input asp-for="Input.ServiceName" class="form-control" />
                            <span asp-validation-for="Input.ServiceName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label"></label>
                            <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ServiceCharge" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="Input.ServiceCharge" class="form-control" />
                            </div>
                            <span asp-validation-for="Input.ServiceCharge" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.SelectedTaxIds" class="form-label"></label>
                            <select asp-for="Input.SelectedTaxIds" asp-items="Model.AvailableTaxes"
                                    class="form-select" multiple size="5">
                            </select>
                            <div class="form-text">
                                <i class="bi bi-info-circle"></i> Hold <kbd>Ctrl</kbd> (Windows) or <kbd>Cmd</kbd> (Mac) to select multiple taxes
                            </div>
                            <span asp-validation-for="Input.SelectedTaxIds" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
