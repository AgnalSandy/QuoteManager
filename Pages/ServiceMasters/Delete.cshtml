@page
@model QuoteManager.Pages.ServiceMasters.DeleteModel
@{
    ViewData["Title"] = "Delete Service";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="mb-4">
        <h1 class="h3 mb-2">Delete Service</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-page="./Index">Service Master</a></li>
                <li class="breadcrumb-item active">Delete</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="alert alert-danger" role="alert">
                <h5 class="alert-heading">
                    <i class="bi bi-exclamation-triangle-fill"></i> Confirm Deletion
                </h5>
                <p class="mb-0">Are you sure you want to delete this service? This action cannot be undone.</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Service Name</dt>
                        <dd class="col-sm-8"><strong>@Model.Service.ServiceName</strong></dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Service.Description</dd>

                        <dt class="col-sm-4">Service Charge</dt>
                        <dd class="col-sm-8">₹@Model.Service.ServiceCharge.ToString("N2")</dd>

                        <dt class="col-sm-4">Applicable Taxes</dt>
                        <dd class="col-sm-8">
                            @if (string.IsNullOrEmpty(Model.Service.ApplicableTaxes))
                            {
                                <span class="text-muted">No taxes</span>
                            }
                            else
                            {
                                @Model.Service.ApplicableTaxes
                            }
                        </dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.Service.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <form method="post" class="mt-3">
                <input type="hidden" asp-for="Service.Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Yes, Delete Service
                    </button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
