@page
@model QuoteManager.Pages.Client.DashboardModel
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <!-- Content Header -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Client Dashboard</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item active">Dashboard</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <!-- Welcome Card -->
            <div class="row">
                <div class="col-12">
                    <div class="card card-primary card-outline">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fas fa-user-circle"></i> @Model.WelcomeMessage
                            </h3>
                        </div>
                        <div class="card-body">
                            <p class="lead">Welcome to your QuoteManager dashboard. Track your quotes and manage your account.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quote Statistics Cards -->
            <div class="row">
                <div class="col-lg-3 col-6">
                    <a asp-page="/Client/Quotes" asp-route-statusFilter="All" style="text-decoration: none;">
                        <div class="small-box bg-info">
                            <div class="inner">
                                <h3>@Model.TotalQuotes</h3>
                                <p>Total Quotes</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-file-invoice"></i>
                            </div>
                            <div class="small-box-footer">
                                View All <i class="fas fa-arrow-circle-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-3 col-6">
                    <a asp-page="/Client/Quotes" asp-route-statusFilter="Pending" style="text-decoration: none;">
                        <div class="small-box bg-warning">
                            <div class="inner">
                                <h3>@Model.PendingQuotes</h3>
                                <p>Pending</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div class="small-box-footer">
                                Action Required <i class="fas fa-arrow-circle-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-3 col-6">
                    <a asp-page="/Client/Quotes" asp-route-statusFilter="Accepted" style="text-decoration: none;">
                        <div class="small-box bg-success">
                            <div class="inner">
                                <h3>@Model.AcceptedQuotes</h3>
                                <p>Accepted</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-check-circle"></i>
                            </div>
                            <div class="small-box-footer">
                                View Accepted <i class="fas fa-arrow-circle-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-3 col-6">
                    <a asp-page="/Client/Quotes" asp-route-statusFilter="Rejected" style="text-decoration: none;">
                        <div class="small-box bg-danger">
                            <div class="inner">
                                <h3>@Model.RejectedQuotes</h3>
                                <p>Rejected</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-times-circle"></i>
                            </div>
                            <div class="small-box-footer">
                                View Rejected <i class="fas fa-arrow-circle-right"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Invoice Statistics Cards -->
            <div class="row">
                <div class="col-lg-4 col-6">
                    <div class="info-box bg-info">
                        <span class="info-box-icon"><i class="fas fa-file-invoice"></i></span>
                        <div class="info-box-content">
                            <span class="info-box-text">Total Invoices</span>
                            <span class="info-box-number">@Model.TotalInvoices</span>
                            <div class="progress">
                                <div class="progress-bar" style="width: 100%"></div>
                            </div>
                            <span class="progress-description">
                                @Model.TotalInvoiceAmount.ToString("C")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-6">
                    <div class="info-box bg-success">
                        <span class="info-box-icon"><i class="fas fa-check-circle"></i></span>
                        <div class="info-box-content">
                            <span class="info-box-text">Paid Invoices</span>
                            <span class="info-box-number">@Model.PaidInvoices</span>
                            <div class="progress">
                                <div class="progress-bar" style="width: @((Model.TotalInvoices > 0 ? (Model.PaidInvoices * 100.0 / Model.TotalInvoices) : 0).ToString("F0"))%"></div>
                            </div>
                            <span class="progress-description">
                                @Model.PaidAmount.ToString("C")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-6">
                    <div class="info-box bg-warning">
                        <span class="info-box-icon"><i class="fas fa-exclamation-circle"></i></span>
                        <div class="info-box-content">
                            <span class="info-box-text">Unpaid Invoices</span>
                            <span class="info-box-number">@Model.UnpaidInvoices</span>
                            <div class="progress">
                                <div class="progress-bar" style="width: @((Model.TotalInvoices > 0 ? (Model.UnpaidInvoices * 100.0 / Model.TotalInvoices) : 0).ToString("F0"))%"></div>
                            </div>
                            <span class="progress-description">
                                @Model.UnpaidAmount.ToString("C") pending
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- My Quotes List -->
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-success">
                            <h3 class="card-title">
                                <i class="fas fa-file-invoice-dollar"></i> Recent Quotes
                            </h3>
                        </div>
                        <div class="card-body p-0">
                            @if (Model.MyQuotes.Any())
                            {
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var quote in Model.MyQuotes)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@quote.Title</strong>
                                                    @if (!string.IsNullOrEmpty(quote.Description))
                                                    {
                                                        <br />

                                                        <small class="text-muted">@quote.Description</small>
                                                    }
                                                </td>
                                                <td><strong>@quote.GrandTotal.ToString("C")</strong></td>
                                                <td>
                                                    @if (quote.Status == "Pending")
                                                    {
                                                        <span class="badge badge-warning">
                                                            <i class="fas fa-clock"></i> Pending
                                                        </span>
                                                    }
                                                    else if (quote.Status == "Accepted")
                                                    {
                                                        <span class="badge badge-success">
                                                            <i class="fas fa-check"></i> Accepted
                                                        </span>
                                                    }
                                                    else if (quote.Status == "Rejected")
                                                    {
                                                        <span class="badge badge-danger">
                                                            <i class="fas fa-times"></i> Rejected
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    <small>@quote.CreatedDate.ToLocalTime().ToString("MMM dd, yyyy")</small>
                                                </td>
                                                <td>
                                                    <a asp-page="/Quotes/Details" asp-route-id="@quote.Id" class="btn btn-sm btn-info">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                    @if (quote.Status == "Pending")
                                                    {
                                                        <a asp-page="/Quotes/ClientAction" asp-route-id="@quote.Id" class="btn btn-sm btn-success">
                                                            <i class="fas fa-check-circle"></i> Respond
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="p-3 text-center text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3"></i>
                                    <p>No quotes yet. Contact your account manager to request a quote.</p>
                                </div>
                            }
                        </div>
                        @if (Model.MyQuotes.Any())
                        {
                            <div class="card-footer">
                                <a asp-page="/Client/Quotes" class="btn btn-primary">
                                    <i class="fas fa-list"></i> View All Quotes
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <!-- Recent Invoices -->
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-info">
                            <h3 class="card-title">
                                <i class="fas fa-file-invoice"></i> Recent Invoices
                            </h3>
                        </div>
                        <div class="card-body p-0">
                            @if (Model.MyInvoices.Any())
                            {
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Invoice #</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var invoice in Model.MyInvoices)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@invoice.InvoiceNumber</strong>
                                                    @if (invoice.Quote != null)
                                                    {
                                                        <br />
                                                        <small class="text-muted">@invoice.Quote.Title</small>
                                                    }
                                                </td>
                                                <td><strong>@invoice.GrandTotal.ToString("C")</strong></td>
                                                <td>
                                                    @if (invoice.IsPaid)
                                                    {
                                                        <span class="badge badge-success">
                                                            <i class="fas fa-check-circle"></i> Paid
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">
                                                            <i class="fas fa-exclamation-circle"></i> Unpaid
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    <small>@invoice.InvoiceDate.ToLocalTime().ToString("MMM dd, yyyy")</small>
                                                    <br />
                                                    <small class="text-muted">Due: @invoice.DueDate.ToString("MMM dd, yyyy")</small>
                                                </td>
                                                <td>
                                                    <a asp-page="/Invoices/Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-info">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="p-3 text-center text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3"></i>
                                    <p>No invoices yet.</p>
                                </div>
                            }
                        </div>
                        @if (Model.MyInvoices.Any())
                        {
                            <div class="card-footer">
                                <a asp-page="/Client/Invoices" class="btn btn-primary">
                                    <i class="fas fa-list"></i> View All Invoices
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Support Team Row -->
            <div class="row">
                <!-- Financial Overview -->
                <div class="col-md-4">
                    <!-- Quote Value Card -->
                    <div class="card card-primary card-outline">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fas fa-chart-line"></i> Financial Overview
                            </h3>
                        </div>
                        <div class="card-body p-0">
                            <ul class="nav flex-column">
                                <li class="nav-item">
                                    <span class="nav-link">
                                        Total Quote Value
                                        <span class="float-right badge bg-primary">
                                            @Model.TotalQuoteValue.ToString("C")
                                        </span>
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <span class="nav-link">
                                        Accepted Value
                                        <span class="float-right badge bg-success">
                                            @Model.AcceptedValue.ToString("C")
                                        </span>
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <span class="nav-link">
                                        Pending Value
                                        <span class="float-right badge bg-warning">
                                            @Model.PendingValue.ToString("C")
                                        </span>
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <span class="nav-link">
                                        Total Invoice Amount
                                        <span class="float-right badge bg-info">
                                            @Model.TotalInvoiceAmount.ToString("C")
                                        </span>
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <span class="nav-link">
                                        Paid Amount
                                        <span class="float-right badge bg-success">
                                            @Model.PaidAmount.ToString("C")
                                        </span>
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <span class="nav-link">
                                        Unpaid Amount
                                        <span class="float-right badge bg-danger">
                                            @Model.UnpaidAmount.ToString("C")
                                        </span>
                                    </span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Support Team Card -->
                <div class="col-md-8">
                    <div class="card card-success card-outline">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fas fa-headset"></i> Your Support Team
                            </h3>
                        </div>
                        <div class="card-body">
                            @if (Model.HasAssignedStaff && Model.AssignedStaff != null)
                            {
                                <h5><strong>Account Manager:</strong></h5>
                                <div class="info-box bg-light">
                                    <span class="info-box-icon bg-success">
                                        <i class="fas fa-user-tie"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">@Model.AssignedStaff.FullName</span>
                                        <span class="info-box-number">
                                            <small>
                                                <i class="fas fa-envelope"></i>
                                                <a href="mailto:@Model.AssignedStaff.Email">@Model.AssignedStaff.Email</a>
                                            </small>
                                        </span>
                                        @if (!string.IsNullOrEmpty(Model.AssignedStaff.PhoneNumber))
                                        {
                                            <span class="info-box-number">
                                                <small>
                                                    <i class="fas fa-phone"></i> @Model.AssignedStaff.PhoneNumber
                                                </small>
                                            </span>
                                        }
                                    </div>
                                </div>

                                @if (Model.SupervisingAdmin != null)
                                {
                                    <hr />
                                    <h5><strong>Supervisor:</strong></h5>
                                    <div class="info-box bg-light">
                                        <span class="info-box-icon bg-warning">
                                            <i class="fas fa-user-shield"></i>
                                        </span>
                                        <div class="info-box-content">
                                            <span class="info-box-text">@Model.SupervisingAdmin.FullName</span>
                                            <span class="info-box-number">
                                                <small>
                                                    <i class="fas fa-envelope"></i>
                                                    <a href="mailto:@Model.SupervisingAdmin.Email">@Model.SupervisingAdmin.Email</a>
                                                </small>
                                            </span>
                                            <span class="progress-description">
                                                <small class="text-muted">Contact if you have issues</small>
                                            </span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>No Account Manager Assigned</strong>
                                    <p>Please contact support.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="row">
                <div class="col-12">
                    <div class="card card-primary card-outline">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fas fa-bolt"></i> Quick Actions
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
                                    <a asp-page="/Client/Quotes" class="btn btn-app bg-success btn-lg w-100">
                                        <i class="fas fa-list fa-2x"></i>
                                        <span class="d-block mt-2">View All Quotes</span>
                                    </a>
                                </div>
                                <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
                                    <a asp-page="/Client/Invoices" class="btn btn-app bg-info btn-lg w-100">
                                        <i class="fas fa-file-invoice-dollar fa-2x"></i>
                                        <span class="d-block mt-2">My Invoices</span>
                                    </a>
                                </div>
                                <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
                                    @if (Model.HasAssignedStaff && Model.AssignedStaff != null)
                                    {
                                        <a href="mailto:@Model.AssignedStaff.Email" class="btn btn-app bg-warning btn-lg w-100">
                                            <i class="fas fa-envelope fa-2x"></i>
                                            <span class="d-block mt-2">Contact Manager</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-app bg-secondary btn-lg w-100" disabled>
                                            <i class="fas fa-envelope fa-2x"></i>
                                            <span class="d-block mt-2">No Manager</span>
                                        </button>
                                    }
                                </div>
                                <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
                                    <a asp-page="/Identity/Account/Manage" class="btn btn-app bg-primary btn-lg w-100">
                                        <i class="fas fa-user-cog fa-2x"></i>
                                        <span class="d-block mt-2">Account Settings</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>
