@page
@model QuoteManager.Pages.Quotes.CreateModel
@{
    ViewData["Title"] = "Create Quote";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-file-invoice"></i> Create Quote</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="Index">Quotes</a></li>
                    <li class="breadcrumb-item active">Create</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <form method="post" id="quoteForm">
            <div class="row">
                <div class="col-md-12">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <!-- Quote Header Information -->
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary">
                            <h3 class="card-title mb-0">
                                <i class="fas fa-info-circle"></i> Quote Information
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Input.ClientId" class="required">Client</label>
                                        <select asp-for="Input.ClientId" class="form-control select2">
                                            <option value="">-- Select Client --</option>
                                            @foreach (var client in Model.Input.AvailableClients)
                                            {
                                                <option value="@client.Value">@client.Text</option>
                                            }
                                        </select>
                                        <span asp-validation-for="Input.ClientId" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Input.ValidUntil">Valid Until</label>
                                        <input asp-for="Input.ValidUntil" class="form-control" type="date" />
                                        <span asp-validation-for="Input.ValidUntil" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label asp-for="Input.Title">Quote Title <small class="text-muted">(Auto-generated if left blank)</small></label>
                                        <input asp-for="Input.Title" class="form-control" placeholder="Leave blank to auto-generate from services" />
                                        <span asp-validation-for="Input.Title" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group mb-0">
                                        <label asp-for="Input.Description">Description <small class="text-muted">(Optional)</small></label>
                                        <textarea asp-for="Input.Description" class="form-control" rows="2" placeholder="Brief description of the project..."></textarea>
                                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Quote Items -->
                    <div class="card shadow-sm">
                        <div class="card-header bg-success">
                            <h3 class="card-title mb-0">
                                <i class="fas fa-list"></i> Services & Items
                            </h3>
                            <div class="card-tools">
                                <button type="button" class="btn btn-sm btn-light" onclick="addQuoteItem()">
                                    <i class="fas fa-plus"></i> Add Item
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div id="quoteItemsContainer">
                                <!-- Quote items will be added here via JavaScript -->
                            </div>
                        </div>
                        <div class="card-footer bg-light">
                            <div class="row">
                                <div class="col-md-8 col-sm-7 text-right">
                                    <p class="mb-1">Sub Total:</p>
                                </div>
                                <div class="col-md-4 col-sm-5 text-right">
                                    <p class="mb-1 font-weight-bold"><span id="subTotalDisplay">₹0.00</span></p>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-8 col-sm-7 text-right">
                                    <p class="mb-2">Total Tax:</p>
                                </div>
                                <div class="col-md-4 col-sm-5 text-right">
                                    <p class="mb-2 font-weight-bold"><span id="totalTaxDisplay">₹0.00</span></p>
                                </div>
                            </div>
                            <hr class="my-2" />
                            <div class="row">
                                <div class="col-md-8 col-sm-7 text-right">
                                    <h5 class="mb-0">Grand Total:</h5>
                                </div>
                                <div class="col-md-4 col-sm-5 text-right">
                                    <h5 class="mb-0 text-success font-weight-bold"><span id="grandTotalDisplay">₹0.00</span></h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="row">
                        <div class="col-md-12">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Create Quote
                            </button>
                            <a asp-page="Index" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

<!-- Template for new quote items -->
<template id="quoteItemTemplate">
    <div class="quote-item-row card mb-3 shadow-sm">
        <div class="card-header bg-light py-2">
            <div class="d-flex justify-content-between align-items-center">
                <div class="custom-control custom-switch">
                    <input type="checkbox" class="custom-control-input custom-service-checkbox" id="customService_INDEX" name="Input.Items[INDEX].IsCustomService" value="true" onchange="toggleCustomService(this)">
                    <label class="custom-control-label" for="customService_INDEX">
                        <small class="text-muted"><i class="fas fa-wrench"></i> Use Custom Service</small>
                    </label>
                </div>
                <button type="button" class="btn btn-danger btn-sm" onclick="removeQuoteItem(this)" title="Remove Item">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <!-- Catalog Service Selection -->
            <div class="service-catalog-row">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Service <span class="text-danger">*</span></label>
                            <select name="Input.Items[INDEX].ServiceId" class="form-control service-select" onchange="updateServicePrice(this)" required>
                                <option value="">-- Select Service --</option>
                                @foreach (var service in Model.Input.AvailableServices)
                                {
                                    <option value="@service.Value">@service.Text</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Notes <small class="text-muted">(Optional)</small></label>
                            <input type="text" name="Input.Items[INDEX].CustomDescription" class="form-control catalog-description" placeholder="Any special requirements..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Service Fields -->
            <div class="custom-service-row" style="display: none;">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Service Name <span class="text-danger">*</span></label>
                            <input type="text" name="Input.Items[INDEX].CustomServiceName" class="form-control custom-service-name" placeholder="Enter custom service name..." />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Description <small class="text-muted">(Optional)</small></label>
                            <input type="text" name="Input.Items[INDEX].CustomDescription" class="form-control custom-service-desc" placeholder="Describe the service..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pricing & Quantities -->
            <div class="row">
                <div class="col-md-2">
                    <div class="form-group">
                        <label>Quantity <span class="text-danger">*</span></label>
                        <input type="number" name="Input.Items[INDEX].Quantity" class="form-control quantity-input" value="1" min="0.01" step="0.01" onchange="calculateItemAmount(this)" required />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Unit Price (₹) <span class="text-danger">*</span></label>
                        <input type="number" name="Input.Items[INDEX].UnitPrice" class="form-control price-input" value="0" min="0" step="0.01" onchange="calculateItemAmount(this)" required />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Taxes <small class="text-muted">(Optional)</small></label>
                        <select name="Input.Items[INDEX].SelectedTaxIds" class="form-control tax-select" multiple onchange="calculateTotals()">
                            @foreach (var tax in Model.Input.AvailableTaxes)
                            {
                                <option value="@tax.Value" data-rate="@tax.Value">@tax.Text</option>
                            }
                        </select>
                        <small class="form-text text-muted">Hold Ctrl to select multiple</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Amount</label>
                        <input type="text" class="form-control amount-display bg-light font-weight-bold" readonly value="₹0.00" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let itemIndex = @Model.Input.Items.Count;

        // Load service prices and tax rates from server
        const servicePrices = {
            @foreach (var kvp in Model.ServicePrices)
            {
                <text>@kvp.Key: @kvp.Value,</text>
            }
        };

        const taxRates = {
            @foreach (var kvp in Model.TaxRates)
            {
                <text>@kvp.Key: @kvp.Value,</text>
            }
        };

        function addQuoteItem() {
            const template = document.getElementById('quoteItemTemplate');
            const container = document.getElementById('quoteItemsContainer');
            const clone = template.content.cloneNode(true);
            
            // Replace INDEX placeholder with actual index
            const html = clone.querySelector('.quote-item-row').outerHTML.replace(/INDEX/g, itemIndex);
            container.insertAdjacentHTML('beforeend', html);
            
            itemIndex++;
            calculateTotals();
        }

        function toggleCustomService(checkbox) {
            const row = checkbox.closest('.quote-item-row');
            const catalogRow = row.querySelector('.service-catalog-row');
            const customRow = row.querySelector('.custom-service-row');
            const serviceSelect = row.querySelector('.service-select');
            const customServiceName = row.querySelector('.custom-service-name');
            const catalogDesc = row.querySelector('.catalog-description');
            const customDesc = row.querySelector('.custom-service-desc');
            const priceInput = row.querySelector('.price-input');
            
            if (checkbox.checked) {
                // Switch to custom service mode
                catalogRow.style.display = 'none';
                customRow.style.display = 'block';
                
                // Disable catalog service validation
                serviceSelect.removeAttribute('required');
                serviceSelect.disabled = true;
                serviceSelect.value = '';
                catalogDesc.value = '';
                
                // Enable custom service validation
                customServiceName.setAttribute('required', 'required');
                customServiceName.disabled = false;
                
                // Allow manual price entry
                priceInput.value = '0';
                priceInput.removeAttribute('readonly');
                priceInput.disabled = false;
            } else {
                // Switch to catalog service mode
                catalogRow.style.display = 'block';
                customRow.style.display = 'none';
                
                // Enable catalog service validation
                serviceSelect.setAttribute('required', 'required');
                serviceSelect.disabled = false;
                
                // Disable custom service validation
                customServiceName.removeAttribute('required');
                customServiceName.disabled = true;
                customServiceName.value = '';
                customDesc.value = '';
                
                // Reset price
                priceInput.value = '0';
            }
            calculateItemAmount(priceInput);
        }

        function removeQuoteItem(button) {
            const row = button.closest('.quote-item-row');
            row.remove();
            calculateTotals();
        }

        function updateServicePrice(selectElement) {
            const row = selectElement.closest('.quote-item-row');
            const priceInput = row.querySelector('.price-input');
            const taxSelect = row.querySelector('.tax-select');
            const serviceId = selectElement.value;
            
            if (serviceId && servicePrices[serviceId]) {
                priceInput.value = servicePrices[serviceId];
                
                // Fetch service details including associated taxes
                fetch(`/Api/GetServiceDetails?serviceId=${serviceId}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.taxes && data.taxes.length > 0) {
                            // Auto-select taxes associated with this service
                            const taxIds = data.taxes.map(t => t.taxId.toString());
                            
                            // Clear current selections
                            Array.from(taxSelect.options).forEach(option => {
                                option.selected = false;
                            });
                            
                            // Select the service's taxes
                            Array.from(taxSelect.options).forEach(option => {
                                if (taxIds.includes(option.value)) {
                                    option.selected = true;
                                }
                            });
                        }
                        
                        calculateItemAmount(priceInput);
                    })
                    .catch(error => {
                        console.error('Error fetching service details:', error);
                        // Still calculate without tax auto-selection if error occurs
                        calculateItemAmount(priceInput);
                    });
            } else {
                calculateItemAmount(priceInput);
            }
        }

        function calculateItemAmount(element) {
            const row = element.closest('.quote-item-row');
            const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
            const price = parseFloat(row.querySelector('.price-input').value) || 0;
            const amount = quantity * price;
            
            row.querySelector('.amount-display').value = '₹' + amount.toFixed(2);
            calculateTotals();
        }

        function calculateTotals() {
            let subTotal = 0;
            let totalTax = 0;

            document.querySelectorAll('.quote-item-row').forEach(row => {
                const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
                const price = parseFloat(row.querySelector('.price-input').value) || 0;
                const itemAmount = quantity * price;
                subTotal += itemAmount;

                // Calculate taxes for this item
                const taxSelect = row.querySelector('.tax-select');
                const selectedTaxes = Array.from(taxSelect.selectedOptions);
                selectedTaxes.forEach(option => {
                    const taxId = option.value;
                    const taxRate = parseFloat(taxRates[taxId]) || 0;
                    const taxAmount = (itemAmount * taxRate) / 100;
                    totalTax += taxAmount;
                });
            });

            const grandTotal = subTotal + totalTax;

            document.getElementById('subTotalDisplay').textContent = '₹' + subTotal.toFixed(2);
            document.getElementById('totalTaxDisplay').textContent = '₹' + totalTax.toFixed(2);
            document.getElementById('grandTotalDisplay').textContent = '₹' + grandTotal.toFixed(2);
        }

        // Initialize calculations on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Add initial quote item
            addQuoteItem();
        });
    </script>
}
