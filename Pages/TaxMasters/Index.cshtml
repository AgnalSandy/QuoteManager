@page
@model QuoteManager.Pages.TaxMasters.IndexModel
@{
    ViewData["Title"] = "Tax Master";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Tax Master</h1>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Tax
        </a>
    </div>

    @if (Model.Taxes.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No taxes found. Click "Add New Tax" to create one.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Tax Name</th>
                                <th>Percentage</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tax in Model.Taxes)
                            {
                                <tr>
                                    <td><strong>@tax.TaxName</strong></td>
                                    <td>@tax.TaxPercentage%</td>
                                    <td>@tax.Description</td>
                                    <td>
                                        @if (tax.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-page="Edit" asp-route-id="@tax.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <a asp-page="Delete" asp-route-id="@tax.Id" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
