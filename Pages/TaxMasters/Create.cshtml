@page
@model QuoteManager.Pages.TaxMasters.CreateModel
@{
    ViewData["Title"] = "Create Tax";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="mb-4">
        <h1 class="h3 mb-2">Create New Tax</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-page="./Index">Tax Master</a></li>
                <li class="breadcrumb-item active">Create</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.TaxName" class="form-label"></label>
                            <input asp-for="Input.TaxName" class="form-control" placeholder="e.g., GST, CGST, SGST" />
                            <span asp-validation-for="Input.TaxName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.TaxPercentage" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Input.TaxPercentage" class="form-control" placeholder="18.00" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="Input.TaxPercentage" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label"></label>
                            <textarea asp-for="Input.Description" class="form-control" rows="3"
                                      placeholder="Brief description of the tax"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create Tax
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
